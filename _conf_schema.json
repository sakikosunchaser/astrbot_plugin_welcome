{
  "enabled": {
    "description": "是否开启入群欢迎",
    "type": "bool",
    "default": true
  },
  "welcome_list": {
    "description": "每个群分别设置欢迎消息和欢迎图片",
    "type": "list",
    "items": {
      "type": "object",
      "items": {
        "group_id": {
          "description": "群号",
          "type": "string",
          "default": "",
          "hint": "例如：123456789"
        },
        "welcome_text": {
          "description": "对应的欢迎消息",
          "type": "string",
          "default": "欢迎新成员加入本群~"
        },
        "image_url": {
          "description": "对应的欢迎图片，可为空。支持公网 URL 或本地相对路径",
          "type": "string",
          "default": "",
          "hint": "例如：https://example.com/welcome.jpg 或 images/welcome.png"
        }
      }
    },
    "default": []
  }
}